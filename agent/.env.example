# JADSlink Agent Configuration
# Copy this file to .env and fill in your node credentials

# ============================================
# NODE IDENTITY (REQUIRED)
# ============================================
# Get these values from the JADSlink dashboard when creating a node
NODE_ID=00000000-0000-0000-0000-000000000000
API_KEY=generate-from-dashboard

# ============================================
# SERVER CONNECTION
# ============================================
SERVER_URL=https://api.jadslink.io

# ============================================
# NETWORK CONFIGURATION
# ============================================
# IP address of this router/gateway
ROUTER_IP=192.168.1.1

# Port for captive portal HTTP server
# Use 80 for production, 8080 for testing
PORTAL_PORT=80

# Interface to bind portal server
# 0.0.0.0 = all interfaces (recommended)
PORTAL_HOST=0.0.0.0

# ============================================
# TIMING INTERVALS (seconds)
# ============================================
# How often to send heartbeat to server
HEARTBEAT_INTERVAL=30

# How often to sync tickets from server
SYNC_INTERVAL=300

# How often to check for expired sessions
EXPIRE_INTERVAL=60

# ============================================
# STORAGE
# ============================================
# Directory for local SQLite cache
CACHE_DIR=./.cache
