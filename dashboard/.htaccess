# SPA Router Configuration for React Router
# Redirige todas las rutas a index.html para que React Router maneje el routing

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /dashboard/

  # Si es una solicitud a un archivo que existe, servirlo directamente
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [QSA,L]

  # Si es una solicitud a un directorio que existe, servirlo directamente
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [QSA,L]

  # Para todas las demás rutas, redirigir a index.html
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# Cache control
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>
