<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /dashboard/

  # Servir archivos y carpetas que existen
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Redirigir todas las demás peticiones a index.html (SPA)
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# Configurar headers correctos para MIME types
<FilesMatch "\.js$">
  AddType application/javascript .js
  AddEncoding gzip .js
</FilesMatch>

<FilesMatch "\.css$">
  AddType text/css .css
  AddEncoding gzip .css
</FilesMatch>

# Cache headers para assets con hash
<FilesMatch "assets/.*\.(js|css)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Cache headers para index.html (sin cache)
<FilesMatch "index\.html$">
  Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>
