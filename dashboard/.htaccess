# Habilitar mod_rewrite
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /dashboard/

  # No reescribir si es un archivo real
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^.*$ - [L]

  # Reescribir todas las demás URLs a index.html (SPA)
  RewriteCond %{REQUEST_URI} !^/dashboard/index\.html$
  RewriteRule ^(.*)$ index.html [L]
</IfModule>

# Deshabilitar compresión automática para JS/CSS compilados
<IfModule mod_deflate.c>
  SetEnvIfNoCase Request_URI "\.js$" no-gzip
  SetEnvIfNoCase Request_URI "\.css$" no-gzip
</IfModule>

# MIME types correctos
<FilesMatch "\.js$">
  AddType application/javascript .js
  Header set Content-Type "application/javascript"
</FilesMatch>

<FilesMatch "\.css$">
  AddType text/css .css
</FilesMatch>

# Cache headers
<FilesMatch "\.(js|css)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

<FilesMatch "index\.html$">
  Header set Cache-Control "public, max-age=0, must-revalidate"
</FilesMatch>
