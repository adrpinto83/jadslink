# JADSlink Local Development Environment
# Copy this to .env and fill in actual values

# FastAPI
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://jads:jadspass@db:5432/jadslink

# Redis
REDIS_URL=redis://redis:6379/0

# Security Keys (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your_secret_key_here_generate_new_one
TICKET_HMAC_SECRET=your_hmac_secret_here_generate_new_one

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=15
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Agent Configuration (for field nodes)
AGENT_NODE_ID=node-001
AGENT_SERVER_URL=http://localhost:8000
AGENT_API_KEY=generate-unique-key-per-node
AGENT_ROUTER_IP=192.168.1.1
AGENT_ROUTER_USER=admin
AGENT_ROUTER_PASS=password

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
